# =============================================================================
# Minimum to fill in: the three credentials + your repo/space identifiers.
# Everything else has working defaults.
#
# Keep the API key / PAT OUT of this file — export them instead:
#   export TF_VAR_octopus_api_key="API-xxxxxxxx"
#   export TF_VAR_github_token="github_pat_xxxx"
# and make sure your terminal is authenticated to AWS (SSO/profile/env).
# =============================================================================

# ── GitHub (forked repo) ──────────────────────────────────────────────────────
github_owner      = "your-org-or-user"
github_repository = "kubearchinspect"   # name of YOUR fork

# ── Octopus ────────────────────────────────────────────────────────────────────
octopus_server_url  = "https://your-instance.octopus.app"
# octopus_polling_url is auto-derived for Octopus Cloud as
# https://polling.your-instance.octopus.app — leave it unset on Cloud. Set it
# only for self-hosted servers (e.g. "https://octopus.example.com:10943").
# octopus_polling_url = ""
octopus_space_id    = "Spaces-2"      # ID of YOUR "ARM Exercise" space — look it up (README step 3)
octopus_space_name  = "ARM Exercise"

# ── AWS / cluster ───────────────────────────────────────────────────────────────
aws_region      = "us-east-1"
cluster_name    = "dvb-eks-arm"
cluster_version = "1.32"

# ── VPC: leave create_vpc = true to let Terraform build it. ──────────────────────
# If your AWS permissions can't create VPCs, set create_vpc = false and supply:
create_vpc = true
# vpc_id     = "vpc-xxxxxxxx"
# subnet_ids = ["subnet-aaa", "subnet-bbb", "subnet-ccc"]

# ── ECR ───────────────────────────────────────────────────────────────────────
ecr_repository_name  = "kubearchinspect"
create_ecr_push_user = true   # set false to use GitHub OIDC instead (see README)

# ── Octopus agent / worker ────────────────────────────────────────────────────
install_octopus_agent  = true
install_octopus_worker = true
environments           = ["Development", "Staging", "Production"]

tags = {
  Environment = "demo"
  ManagedBy   = "terraform"
}
